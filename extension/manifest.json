{
  "manifest_version": 3,
  "name": "NASA Landsat Image Downloader",
  "description": "Generate and download NASA Landsat letter images from captions. Images are saved to your Downloads/nasa_images folder.",
  "version": "1.0.0",
  "permissions": [
    "downloads",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://science.nasa.gov/*",
    "https://landsat.gsfc.nasa.gov/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://science.nasa.gov/specials/your-name-in-landsat/*"],
      "js": ["content.js"],
      "css": ["content-overlay.css"]
    }
  ]
}
